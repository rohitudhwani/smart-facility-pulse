        "import os, time, subprocess\n",
        "from pyngrok import ngrok\n",
        "\n",
        "APP_PATH = '/content/drive/MyDrive/smart-facility-pulse/app/streamlit_app.py'\n",
        "LOG_PATH = '/content/streamlit.log'\n",
        "\n",
        "ngrok.kill()\n",
        "os.system('pkill -9 -f streamlit 2>/dev/null')\n",
        "time.sleep(3)\n",
        "\n",
        "with open(LOG_PATH, 'w') as logfile:\n",
        "    subprocess.Popen(\n",
        "        ['streamlit', 'run', APP_PATH,\n",
        "         '--server.port', '8501', '--server.headless', 'true',\n",
        "         '--server.enableCORS', 'false', '--server.enableXsrfProtection', 'false',\n",
        "         '--browser.gatherUsageStats', 'false', '--server.fileWatcherType', 'none'],\n",
        "        stdout=logfile, stderr=subprocess.STDOUT,\n",
        "    )\n",
        "\n",
        "ready = False\n",
        "for i in range(30):\n",
        "    time.sleep(1)\n",
        "    try:\n",
        "        with open(LOG_PATH) as f:\n",
        "            if 'Local URL' in f.read():\n",
        "                ready = True\n",
        "                break\n",
        "    except Exception:\n",
        "        pass\n",
        "\n",
        "if ready:\n",
        "    public_url = ngrok.connect(8501, bind_tls=True)\n",
        "    print(f'\\nDashboard live: {public_url}\\n')\n",
