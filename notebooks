        "    cutoff_24h = comfort_df['timestamp'].max() - timedelta(hours=24)\n",
        "    last_24h = comfort_df[comfort_df['timestamp'] >= cutoff_24h]\n",
        "    outdoor_pm25_24h = weather_df[weather_df['timestamp'] >= cutoff_24h]['outdoor_pm25'].mean()\n",
