        "    # ---- No symptoms — healthy ----\n",
        "    # Small baseline noise so the ranking isn't flat\n",
        "    rng = np.random.RandomState(hash(zone_row['zone_id']) % (2**31))\n",
        "    baseline = rng.uniform(0.02, 0.12)\n",
        "    return {\n",
        "        'fault_type': 'fault_free',\n",
        "        'fault_proba': baseline,\n",
        "        'severity': 'none',\n",
